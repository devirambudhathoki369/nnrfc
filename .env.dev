# Django Settings
SECRET_KEY=django-insecure-dev-secret-key-change-in-production-123456
DEBUG=1
DJANGO_ALLOWED_HOSTS=*
ENVIRONMENT=development

# Database (PostgreSQL in Docker)
DATABASE=postgres
POSTGRES_ENGINE=django.db.backends.postgresql
POSTGRES_DB=nnrfc
