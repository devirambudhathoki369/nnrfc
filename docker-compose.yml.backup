version: "3.7"

services:
  web:
    build: ./app
    command: python manage.py runserver 0.0.0.0:8000
    volumes:
      - ./app/:/usr/src/app/
    ports:
      - 8000:8000
    env_file:
      - ./.env.dev
    depends_on:
      - db
  db:
    image: postgres:12.0-alpine
    volumes:
      - postgres_data:/var/lib/postgresql/data/
    environment:
      - POSTGRES_USER=admin
      - POSTGRES_PASSWORD=admin
      - POSTGRES_DB=nnrfc
  rabbit:
    hostname: rabbit
    image: rabbitmq:3-management
    command: rabbitmq-server
    env_file: .env.dev
    ports:
      - 5673:5672
      - 15672:15672
    volumes:
      - "rabbit_data:/data"

  worker:
    restart: always
    build:
      context: ./app
      dockerfile: Dockerfile
    command: "celery -A nnrfc worker -l INFO"
    volumes:
      - .:/app
    links:
      - rabbit
    depends_on:
      - rabbit
    env_file: .env.dev

volumes:
  postgres_data:
  rabbit_data:
